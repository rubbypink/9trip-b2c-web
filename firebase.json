{
  "hosting": {
    "source": ".",
    "ignore": ["firebase.json", "**/node_modules/**"],
    "frameworksBackend": {
      "region": "asia-southeast1"
    },
    "rewrites": [
      {
        "source": "/api/bookings/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/cart/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/contact",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/availability/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/payments/**",
        "function": "apiPayments",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/webhooks/**",
        "function": "apiWebhooks",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/agents/**",
        "function": "apiAgents",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/auth/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/email/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=300"
          }
        ]
      },
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local", "!.env.local"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
