{
  "hosting": {
    "source": ".",
    "ignore": ["firebase.json", "**/node_modules/**", "functions/",".github"],
    "frameworksBackend": {
      "region": "asia-southeast1",
      "timeoutSeconds": 540,
      "memory": "1GiB"
    },
    "rewrites": [
      {
        "source": "/api/bookings/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/cart/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/contact",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/availability/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/payments/**",
        "function": "apiPayments",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/webhooks/**",
        "function": "apiWebhooks",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/auth/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      },
      {
        "source": "/api/email/**",
        "function": "apiCore",
        "region": "asia-southeast1"
      }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=900"
          }
        ]
      },
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": ["firebase.json", "**/node_modules/**", "functions/", ".github", ".next/dev/**",  ".git", "firebase-debug.log", "firebase-debug.*.log", ".agents/", ".codenomad/", ".opencode/", ".vscode/", ".report/", "specs/", "/.*/"],
      "predeploy": [
			"rm -rf functions/vendor-shared",
			"cp -r packages/shared functions/vendor-shared",
			"node -e \"const fs=require('fs'); const p=JSON.parse(fs.readFileSync('functions/package.json')); p.dependencies['@9trip/shared']='file:./vendor-shared'; fs.writeFileSync('functions/package.json', JSON.stringify(p, null, '\\t')+'\\n');\"",
			"rm -rf ~/projects/tripphuquoc-db-fs/.firebase"
		   ],
      "postdeploy": [
        "node -e \"const fs=require('fs'); const p=JSON.parse(fs.readFileSync('functions/package.json')); p.dependencies['@9trip/shared']='file:../packages/shared'; fs.writeFileSync('functions/package.json', JSON.stringify(p, null, '\\t')+'\\n');\"",
        "rm -rf functions/vendor-shared"
      ]
    }
  ]
}
